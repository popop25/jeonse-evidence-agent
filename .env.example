# Optional Azure OpenAI configuration. Set all six variables together.
# Never commit real values.
AOAI_API_KEY=<your-azure-openai-api-key>
AOAI_ENDPOINT=https://<your-resource>.openai.azure.com
AOAI_DEPLOY_GPT41_MINI=<your-chat-deployment>
AOAI_MODEL_GPT41_MINI=gpt-4.1-mini
AOAI_DEPLOY_EMBED_3_SMALL=<your-embedding-deployment>
AOAI_MODEL_EMBED_3_SMALL=text-embedding-3-small

# Streamlit-to-FastAPI URL.
JEONSE_API_BASE_URL=http://127.0.0.1:8000
